# Backend API Base URL (no trailing slash)
NEXT_PUBLIC_API_URL="https://your-backend-service.onrender.com"

# Firebase Client Configuration (matching your Firebase project)
NEXT_PUBLIC_FIREBASE_API_KEY="your-production-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-production-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-production-project"
NEXT_PUBLIC_FIREBASE_APP_ID="1:production-app-id:web:production-web-id"
