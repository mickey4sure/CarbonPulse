generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Core User ──────────────────────────────────────────────────────────────

model User {
  id                Int           @id @default(autoincrement())
  firebaseUid       String        @unique
  email             String        @unique
  name              String?
  username          String?
  phone             String?
  age               Int?
  region            String?
  country           String?
  avatar            String?
  tutorialCompleted Boolean       @default(false)
  createdAt         DateTime      @default(now())
  activities        ActivityLog[]
  insights          Insight[]
  challengeParticipants ChallengeParticipant[]
  comments              Comment[]

  @@index([firebaseUid])
}

// ─── Carbon Activity Log ─────────────────────────────────────────────────────
// Stores every individual carbon-generating activity a user logs.
// co2Kg is pre-calculated at write time by the backend lib/carbon.ts utility.

model ActivityLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  activityType String   // "transit" | "food" | "energy"
  label        String   // e.g. "Car", "Beef", "Grid Electricity"
  value        Float    // numeric input quantity
  unit         String   // "km" | "grams" | "kwh" | "litres"
  co2Kg        Float    // pre-calculated CO₂ equivalent in kilograms
  loggedAt     DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

// ─── AI-Generated Insights ───────────────────────────────────────────────────
// Stores Gemini-generated personalized sustainability insights.
// Cached for 24 hours to avoid redundant API calls.

model Insight {
  id          Int      @id @default(autoincrement())
  userId      Int
  content     String   // Gemini-generated markdown text
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─── Challenge Join System ───────────────────────────────────────────────────

model ChallengeParticipant {
  id          Int      @id @default(autoincrement())
  userId      Int
  challengeId String   // e.g. "c1", "c2", "c3"
  joinedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
}

// ─── Community Discussion Area ────────────────────────────────────────────────

model Channel {
  id          String    @id // e.g. "general", "zero-waste", "transportation", "diet-food", "energy"
  name        String
  description String
  comments    Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  channelId String
  userId    Int
  content   String
  createdAt DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([userId])
}

