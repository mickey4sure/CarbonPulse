# DATABASE_URL: PostgreSQL Connection String for your live database
DATABASE_URL="postgresql://db_user:db_password@your-database-host:5432/db_name?sslmode=require"

# GEMINI_API_KEY: Your production API Key for generating carbon insights
GEMINI_API_KEY="your-gemini-production-key"

# Port to bind
PORT=3001

# ALLOWED_ORIGIN: Live URL of your frontend app (no trailing slash)
ALLOWED_ORIGIN="https://your-app-domain.vercel.app"

# NODE_ENV: Set to production to enable full security validations and disable mock auth
NODE_ENV=production
